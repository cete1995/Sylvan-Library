# ─── Server ───────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override it on Railway
PORT=5000
NODE_ENV=production

# ─── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB Atlas → your cluster → Connect → Drivers → copy the SRV connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
# Comma-separate multiple origins if needed, e.g. https://a.vercel.app,https://b.vercel.app
FRONTEND_URL=https://your-app.vercel.app
